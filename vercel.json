{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
          {
                  "source": "/api/(.*)",
                  "destination": "https://neocorp-ctf-backend.onrender.com/api/$1"
          },
          {
                  "source": "/system-diagnostic-v2/(.*)",
                  "destination": "https://neocorp-ctf-backend.onrender.com/system-diagnostic-v2/$1"
          },
          {
                  "source": "/system-diagnostic-v2",
                  "destination": "https://neocorp-ctf-backend.onrender.com/system-diagnostic-v2"
          },
          {
                  "source": "/robots.txt",
                  "destination": "https://neocorp-ctf-backend.onrender.com/robots.txt"
          },
          {
                  "source": "/uploads/(.*)",
                  "destination": "https://neocorp-ctf-backend.onrender.com/uploads/$1"
          },
          {
                  "source": "/(.*)",
                  "destination": "/index.html"
          }
    ]
}
